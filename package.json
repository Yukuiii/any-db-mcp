{
  "name": "@sakura0v0/any-db-mcp",
  "version": "1.0.0",
  "description": "MCP Server for MySQL, PostgreSQL, SQLite and Microsoft SQL Server database operations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "any-db-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build && chmod +x dist/index.js"
  },
  "keywords": [
    "mcp",
    "mysql",
    "postgresql",
    "sqlite",
    "mssql",
    "sqlserver",
    "database",
    "model-context-protocol"
  ],
  "author": "Yukuiii",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yukuiii/any-db-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "mssql": "^11.0.1",
    "mysql2": "^3.19.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^12.3.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3"
  }
}
